{
  "language_servers": ["...", "biome"],
  "formatter": "language_server",
  "tab_size": 2,
  "soft_wrap": "preferred_line_length",
  "preferred_line_length": 100,
  "autosave": "on_focus_change",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "languages": {
    "JavaScript": {
      "language_servers": ["typescript-language-server", "..."]
    },
    "TSX": {
      "language_servers": ["typescript-language-server", "..."]
    }
  }
}
